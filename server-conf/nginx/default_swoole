server {
        server_name roodos.com roodos.cl roodos.ec roodos.pe roodos.mx;
        listen 80;
        root /app/public;
        index index.php index.html index.htm index.nginx-debian.html;
        charset       utf-8;

        client_max_body_size 512M;
        large_client_header_buffers 4 16k;

        gzip on;
        gzip_disable "msie6";

        gzip_vary on;
        gzip_proxied any;
        gzip_comp_level 6;
        gzip_buffers 16 8k;
        gzip_http_version 1.1;
        gzip_types text/css application/javascript text/javascript;
        
        add_header Permissions-Policy "browsing-topics=()" always;

        # Redirigir todas las URLs que terminan en "/" a su versión sin "/"
        if ($request_uri ~ ^/(.*)/$) {
                return 301 $scheme://$host/$1;
        }

        location / {
                proxy_pass http://127.0.0.1:8000;
                proxy_set_header Host            $host;
                proxy_set_header X-Forwarded-For $remote_addr;
        }

        location ~*  \.(svg|woff|woff2|jpg|jpeg|png|gif|ico|css|js|webp)$ {
                proxy_pass http://127.0.0.1:8000;
                add_header Pragma public;
                add_header Cache-Control "public";
                expires 120d;
                gzip_static on;
        }
}